! FRR Configuration for ${hostname}
! BGP-only configuration for Talos nodes
! Rendered by Terraform templatefile()
!
frr version 10.2
frr defaults datacenter
hostname ${hostname}
log syslog informational
service integrated-vtysh-config
!
%{ if enable_bfd ~}
! BFD (Bidirectional Forwarding Detection) for fast failover
bfd
 profile normal
  detect-multiplier 3
  receive-interval 300
  transmit-interval 300
 exit
exit
!
%{ endif ~}
! IPv6 and IPv4 prefix lists for default route import
ipv6 prefix-list DEFAULT-ONLY-v6 seq 10 permit ::/0
ip prefix-list DEFAULT-ONLY-v4 seq 10 permit 0.0.0.0/0
!
! Route maps to import only default routes from upstream
route-map IMPORT-DEFAULT-v6 permit 10
 match ipv6 address prefix-list DEFAULT-ONLY-v6
exit
!
route-map IMPORT-DEFAULT-v6 deny 90
exit
!
route-map IMPORT-DEFAULT-v4 permit 10
 match ip address prefix-list DEFAULT-ONLY-v4
exit
!
route-map IMPORT-DEFAULT-v4 deny 90
exit
!
%{ if advertise_loopbacks ~}
! Advertise node loopback networks
ip prefix-list LOOPBACKS seq 10 permit 10.255.${cluster_id}.0/24 ge 32
ipv6 prefix-list LOOPBACKS-V6 seq 10 permit fd00:255:${cluster_id}::/48 ge 128
!
route-map ADVERTISE-LOOPBACKS permit 10
 match ip address prefix-list LOOPBACKS
exit
!
route-map ADVERTISE-LOOPBACKS-V6 permit 10
 match ipv6 address prefix-list LOOPBACKS-V6
exit
!
%{ endif ~}
! BGP Configuration
router bgp ${local_asn}
 bgp router-id ${router_id}
 no bgp default ipv4-unicast
 bgp graceful-restart
 timers bgp 10 30
 !
 ! Peer with upstream (PVE FRR) using link-local IPv6
 neighbor fe80::%${interface} remote-as ${remote_asn}
 neighbor fe80::%${interface} timers connect 5
%{ if enable_bfd ~}
 neighbor fe80::%${interface} bfd
 neighbor fe80::%${interface} bfd profile normal
%{ endif ~}
 !
 address-family ipv4 unicast
  neighbor fe80::%${interface} activate
  neighbor fe80::%${interface} route-map IMPORT-DEFAULT-v4 in
  neighbor fe80::%${interface} extended-nexthop
%{ if advertise_loopbacks ~}
  neighbor fe80::%${interface} route-map ADVERTISE-LOOPBACKS out
%{ endif ~}
 exit-address-family
 !
 address-family ipv6 unicast
  neighbor fe80::%${interface} activate
  neighbor fe80::%${interface} route-map IMPORT-DEFAULT-v6 in
%{ if advertise_loopbacks ~}
  neighbor fe80::%${interface} route-map ADVERTISE-LOOPBACKS-V6 out
%{ endif ~}
 exit-address-family
exit
!
line vty
!
