#!/bin/bash
# Complete BGP diagnostic output
echo "======================================"
echo "FRR BGP Complete Status Report"
echo "Generated: $(date)"
echo "======================================"
echo ""

echo "=== BGP Summary ==="
vtysh -c "show bgp vrf all summary wide"
echo ""

echo "=== BGP Neighbors (IPv4) ==="
vtysh -c "show bgp ipv4 unicast neighbors"
echo ""

echo "=== BGP Neighbors (IPv6) ==="
vtysh -c "show bgp ipv6 unicast neighbors"
echo ""

echo "=== Routes Advertised (IPv4) ==="
vtysh -c "show bgp ipv4 unicast neighbors advertised-routes"
echo ""

echo "=== Routes Received (IPv4) ==="
vtysh -c "show bgp ipv4 unicast neighbors routes"
echo ""

echo "=== Routes Advertised (IPv6) ==="
vtysh -c "show bgp ipv6 unicast neighbors advertised-routes"
echo ""

echo "=== Routes Received (IPv6) ==="
vtysh -c "show bgp ipv6 unicast neighbors routes"
echo ""

echo "=== BGP RIB (IPv4) ==="
vtysh -c "show bgp ipv4 unicast"
echo ""

echo "=== BGP RIB (IPv6) ==="
vtysh -c "show bgp ipv6 unicast"
echo ""

echo "=== Running Configuration ==="
vtysh -c "show running-config"
echo ""

echo "=== Route Summary ==="
vtysh -c "show ip route summary"
vtysh -c "show ipv6 route summary"
echo ""

echo "=== VRF Status ==="
vtysh -c "show vrf"
echo ""

if grep -q "bfdd=true" /etc/frr/daemons 2>/dev/null; then
    echo "=== BFD Status ==="
    vtysh -c "show bfd peers"
    echo ""
fi

echo "======================================"
echo "End of Status Report"
echo "======================================"
